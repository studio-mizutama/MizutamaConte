{
  "name": "mizutama-conte",
  "version": "0.2.0",
  "author": "Studio Mizutama",
  "description": "Easy tool for creating econte.",
  "homepage": "https://studio-mizutama.github.io/MizutamaConte",
  "main": "out/main/main.js",
  "private": true,
  "license": "MIT",
  "dependencies": {
    "@adobe/react-spectrum": "3.11.2",
    "@spectrum-icons/illustrations": "3.2.1",
    "@spectrum-icons/workflow": "3.2.0",
    "ag-psd": "^14.1.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-hotkeys-hook": "^3.3.2",
    "reactn": "^2.2.7",
    "styled-components": "^5.3.0"
  },
  "scripts": {
    "dev": "electron-vite dev -w",
    "dev:web": "vite",
    "build": "electron-vite build",
    "build:web": "vite build",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p electron --noEmit",
    "preview:web": "vite preview",
    "deploy": "yarn build:web && gh-pages -d build"
  },
  "build": {
    "extends": null,
    "appId": "net.studio-mizutama.mizutama-conte",
    "productName": "Mizutama Conte",
    "files": [
      "out/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^17.0.8",
    "@types/react-dom": "^17.0.5",
    "@types/styled-components": "^5.1.11",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "gh-pages": "^3.2.3",
    "typescript": "^5.7",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2"
  },
  "volta": {
    "node": "22.22.3",
    "yarn": "1.22.19"
  }
}
